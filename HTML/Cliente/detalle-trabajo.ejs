<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= trabajo.titulo %> | Carrocerias Sandoval</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
    <link rel="stylesheet" href="/CSS/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
    <header class="header" id="header">
        <nav class="navegador">
            <a href="/Cliente/pagina-cliente" class="nav__logo">
                <span>Carrocerias Sandoval</span>
            </a>

            <div class="nav__toggle" id="nav-toggle">
                <i class="ri-menu-line"></i>
            </div>

            <div class="nav__menu" id="nav-menu">
                <ul class="nav__list">
                    <li class="nav__item"><a href="servicios" class="nav__link">Servicios</a></li>
                    <li class="nav__item"><a href="trabajos" class="nav__link">Trabajos</a></li>
                    <li class="nav__item"><a href="contactos" class="nav__link">Contacto</a></li>
                    <li class="nav__item"><a href="perfil" class="nav__link">Perfil</a></li>
                    <li class="nav__item"><a href="/logout" class="nav__link">Cerrar Sesión</a></li>
                </ul>

                <div class="nav__close" id="nav-close">
                    <i class="ri-close-line"></i>
                </div>
            </div>
        </nav>
    </header>

    <main class="main detalle-trabajo-page">
        <section class="detalle-header">
            <h1><%= trabajo.titulo %></h1>
            <p><%= trabajo.descripcion %></p>
        </section>

        <section class="detalle-wrapper">
            <section class="carousel-section">
                <div class="carousel-container">
                    <button class="carousel-btn prev" onclick="cambiarSlide(-1)">&#10094;</button>

                    <div class="carousel-slide">
                        <% trabajo.imagenes.forEach((imagen, index) => { %>
                            <img 
                                src="<%= imagen %>" 
                                alt="Imagen <%= index + 1 %> de <%= trabajo.titulo %>"
                                class="carousel-img <%= index === 0 ? 'active' : '' %>"
                            >
                        <% }) %>
                    </div>

                    <button class="carousel-btn next" onclick="cambiarSlide(1)">&#10095;</button>

                    <div class="carousel-counter">
                        <span id="slide-actual">1</span> / <span id="slide-total"><%= trabajo.imagenes.length %></span>
                    </div>
                </div>

                <div class="carousel-thumbs">
                    <% trabajo.imagenes.forEach((imagen, index) => { %>
                        <div class="thumb <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>" onclick="irASlide(this.dataset.index)">
                            <img src="<%= imagen %>" alt="Miniatura <%= index + 1 %> de <%= trabajo.titulo %>">
                        </div>
                    <% }) %>
                </div>

                <a href="/Cliente/trabajos" class="btn-volver">← Volver a trabajos</a>
            </section>
        </section>
    </main>

    <footer class="pie_de_pagina">
        <div class="contenedor_pie1">
            <div class="box">
                <h2>NOSOTROS</h2>
                <p>Somos una empresa con el propósito de entregar un servicio de calidad y darnos a conocer a nivel nacional.</p>
                <p>A través de esta plataforma, buscamos mostrar nuestra trayectoria y los trabajos realizados.</p>
            </div>

            <div class="box">
                <h2>Contáctanos</h2>
                <div class="redes">
                    <a href="https://www.facebook.com/profile.php?id=61570873678977" class="nav_social-iconf">Facebook <i class="ri-facebook-box-line"></i></a>
                    <a href="https://www.instagram.com/carroceriassandoval/" class="nav_social-iconf">Instagram <i class="ri-instagram-box-line"></i></a>
                    <a href="https://www.tiktok.com/@carroceriassandoval?is_from_webapp=1&sender_device=pc" class="nav_social-iconf">Tik-Tok <i class="ri-tiktok-box-line"></i></a>
                </div>
            </div>
        </div>

        <div class="contenedor_pie2">
            <small>&copy; 2026 <b>Carrocerias Sandoval</b> - Todos los derechos reservados.</small>
        </div>
    </footer>

    <script src="/JS/index.js"></script>
    <script>
        let slideActual = 0;
        const slides = document.querySelectorAll('.carousel-img');
        const thumbs = document.querySelectorAll('.thumb');
        const slideActualTexto = document.getElementById('slide-actual');

        function mostrarSlide(index) {
            index = Number(index);

            slides.forEach(slide => slide.classList.remove('active'));
            thumbs.forEach(thumb => thumb.classList.remove('active'));

            slides[index].classList.add('active');
            thumbs[index].classList.add('active');

            if (slideActualTexto) {
                slideActualTexto.textContent = index + 1;
            }

            slideActual = index;
        }

        function cambiarSlide(direccion) {
            let nuevoIndice = slideActual + direccion;

            if (nuevoIndice < 0) {
                nuevoIndice = slides.length - 1;
            }

            if (nuevoIndice >= slides.length) {
                nuevoIndice = 0;
            }

            mostrarSlide(nuevoIndice);
        }

        function irASlide(index) {
            mostrarSlide(index);
        }
    </script>
</body>
</html>