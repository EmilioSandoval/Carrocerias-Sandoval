<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carrocerias Sandoval</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
    <link rel="stylesheet" href="../CSS/style.css">
</head>
<body>
    <header class="header" id="header">
        <nav class="navegador">
            <a href="#" class="nav__logo">
                <span>Carrocerias Sandoval</span>
            </a>
            <div class="nav__toggle" id="nav-toggle">
                <i class="ri-menu-line"></i>
            </div>
            <div class="nav__menu" id="nav-menu">
                <ul class="nav__list">
                    <li class="nav__item"><a href="ordenes-trabajo" class="nav__link">Trabajo</a></li>
                    <li class="nav__item"><a href="historial-clientes" class="nav__link">Historial</a></li>
                    <li class="nav__item"><a href="Inventario-taller" class="nav__link">Inventario</a></li>
                    <li class="nav__item"><a href="configuracion" class="nav__link">Configuración</a></li>
                    <li class="nav__item"><a href="/" class="nav__link">Cerrar Sesión</a></li>
                </ul>
                <div class="nav__close" id="nav-close">
                    <i class="ri-close-line"></i>
                </div>
            </div>
        </nav>
    </header>

   <main class="main">
    <div class="orders-grid">
    <% ordenes.forEach(orden => { %>
        <div class="order-card status-<%= orden.estado.toLowerCase().replace(' ', '-') %>">
            <div class="order-header">
                <h3>Orden #<%= orden.id %></h3>
                <span class="badge"><%= orden.estado %></span>
            </div>
            <div class="order-body">
                <p><strong>Cliente:</strong> <%= orden.cliente_nombre %></p>
                <p><strong>Servicio:</strong> <%= orden.servicio %></p>
                <p><strong>Fecha Prometida:</strong> <%= new Date(orden.fecha_entrega).toLocaleDateString() %></p>
            </div>
            <div class="order-actions">
                <form action="/empleado/ordenes/actualizar-estado" method="POST">
                    <input type="hidden" name="id_orden" value="<%= orden.id %>">
                    <select name="nuevo_estado" onchange="this.form.submit()">
                        <option value="Pendiente" <%= orden.estado === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
                        <option value="En Proceso" <%= orden.estado === 'En Proceso' ? 'selected' : '' %>>En Proceso</option>
                        <option value="Terminado" <%= orden.estado === 'Terminado' ? 'selected' : '' %>>Terminado</option>
                    </select>
                </form>
            </div>
        </div>
    <% }) %>
</div>
</main>

    <footer class="pie_de_pagina">
        <div class="contenedor_pie1">
            <div class="box">
                <h2>NOSOTROS</h2>
                <p>Somos una empresa con el propósito de entregar un servicio de calidad y darnos a conocer a nivel nacional.</p>
                <p>A través de esta plataforma, buscamos mostrar nuestra trayectoria y los trabajos realizados.</p>
            </div>

            <div class="box">
                <h2>Contáctanos</h2>
                <div class="redes">
                    <a href="https://www.facebook.com/profile.php?id=61570873678977" class="nav_social-iconf">Facebook <i class="ri-facebook-box-line"></i></a>
                    <a href="https://www.instagram.com/carroceriassandoval/" class="nav_social-iconf">Instagram <i class="ri-instagram-box-line"></i></a>
                    <a href="https://www.tiktok.com/@carroceriassandoval?is_from_webapp=1&sender_device=pc" class="nav_social-iconf">Tik-Tok <i class="ri-tiktok-box-line"></i></a>
                </div>
            </div>
        </div>
        
        <div class="contenedor_pie2">
            <small>&copy; 2026 <b>Carrocerias Sandoval</b> - Todos los derechos reservados.</small>
        </div>
    </footer>

    <script src="../JS/index.js"></script>
</body>
</html>